{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/yaojingang/GEORank/blob/main/data/public/schemas/expert-state-transition.v1.schema.json",
  "title": "GEORank expert state transition v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "contract",
    "revision",
    "down_revision",
    "effective_date",
    "downgrade_policy",
    "operations"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "contract": {"const": "expert-state-transition"},
    "revision": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_]{2,119}$"},
    "down_revision": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_]{2,119}$"},
    "effective_date": {"type": "string", "format": "date"},
    "downgrade_policy": {"const": "preserve_target_state"},
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/operation"}
    }
  },
  "$defs": {
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation",
        "id",
        "slug",
        "from_state",
        "to_state",
        "reason"
      ],
      "properties": {
        "operation": {"const": "set_publication_state"},
        "id": {
          "type": "string",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
        },
        "slug": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "from_state": {
          "const": {"is_published": true, "is_featured": true}
        },
        "to_state": {
          "const": {"is_published": false, "is_featured": false}
        },
        "reason": {"type": "string", "minLength": 10, "maxLength": 240}
      }
    }
  }
}
