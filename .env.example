# ============================================
# GEOrank — 环境变量配置模板
# 复制本文件为 .env 并填入实际值
# ============================================

# ----- 基础 -----
DEBUG=true
# 生产环境必须改为 false，并使用 HTTPS PUBLIC_BASE_URL 与三组独立随机密钥。
SECRET_KEY=change-me-secret-key
SETTINGS_ENCRYPTION_KEY=change-me-settings-encryption-key
PUBLIC_BASE_URL=http://localhost:3009
# JSON 数组；生产环境仅保留正式域名与内部健康检查所需主机名
TRUSTED_HOSTS=["localhost","127.0.0.1","api","app.georank.com","*.georank.com"]

# ----- PostgreSQL -----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=georank
POSTGRES_USER=georank
POSTGRES_PASSWORD=change-me-postgres-password

# ----- Redis -----
REDIS_HOST=redis
REDIS_PORT=6379

# ----- Qdrant -----
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=companies

# ----- Neo4j -----
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-neo4j-password

# ----- MinIO -----
MINIO_ENDPOINT=minio:9000
MINIO_USER=change-me-minio-access-key
MINIO_PASSWORD=change-me-minio-secret-key

# ----- AI / LLM -----
# 方案一：兼容 OpenAI 格式的第三方服务
# LLM_API_KEY=sk-xxx
# LLM_BASE_URL=https://your-openai-compatible-endpoint/v1
# LLM_MODEL=your-chat-model
#
# 方案二：直连 OpenAI
# LLM_API_KEY=sk-xxx
# LLM_BASE_URL=
# LLM_MODEL=gpt-4o-mini

LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gpt-4o-mini
# Keep false for SSRF protection. Set true only for trusted self-hosted LLMs on private networks;
# this also permits HTTP endpoints, so restrict network access around the backend service.
ALLOW_PRIVATE_LLM_PROVIDER_URLS=false

# 向后兼容
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ----- Embedding（需单独配置兼容 OpenAI 格式的 Embedding 服务，或留空降级同类推荐） -----
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ----- JWT -----
JWT_SECRET=change-me-jwt-secret
JWT_EXPIRE_MINUTES=1440

# ----- 种子账号（可选；留空时 seed 脚本会随机生成一次性密码并打印） -----
GEORANK_SEED_ADMIN_PASSWORD=
GEORANK_SEED_DEMO_PASSWORD=
GEORANK_SEED_TEST_PASSWORD=
