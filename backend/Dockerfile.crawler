FROM mcr.microsoft.com/playwright/python:v1.61.0-jammy@sha256:108b33fc1c785c056665b04c320a612526503b0b081209eea2e1ec89e3b69a8f

WORKDIR /app

# 额外系统依赖
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential curl && \
    rm -rf /var/lib/apt/lists/*

# Python 依赖
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .
COPY --chmod=0755 docker-entrypoint.sh /usr/local/bin/georank-entrypoint

ENTRYPOINT ["/usr/local/bin/georank-entrypoint"]
CMD ["celery", "-A", "app.core.celery_app", "worker", "-l", "info", "-c", "2", "-Q", "crawl"]
